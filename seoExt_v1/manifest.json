{
"manifest_version" : 3,
"name":"SEO EXT V1",
"description" : "A light weight on-page SEO analyzer",
"version":"1.0",
"permissions" : [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon":{
    "16": "Icon/icon16.png",
    "48":"Icon/icon48.png",
    "128":"Icon/icon128.png"
  },
  "default_title": "Analyze SEO"
  },
"icons":{
    "16": "Icon/icon16.png",
    "48":"Icon/icon48.png",
    "128":"Icon/icon128.png"
},
"background": {
  "service_worker": "background.js"
}
}

